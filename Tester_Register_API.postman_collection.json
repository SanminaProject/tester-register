              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"{{login_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const response = pm.response.json();",
                  "  const token = response?.data?.access_token;",
                  "  if (token) {",
